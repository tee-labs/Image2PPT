# Copy to web/.env and edit. All settings are optional — defaults work
# for local development, but you should at minimum override the JWT
# secret and admin password before exposing this to a network.

# Auth — seeded on first launch if no admin exists.
DECKWEAVER_ADMIN_USERNAME=admin
DECKWEAVER_ADMIN_PASSWORD=admin
DECKWEAVER_JWT_SECRET=please-set-a-long-random-string

# Worker — interpreter used to spawn scripts/convert.py.
# Use the same Python you ran bootstrap.sh with.
DECKWEAVER_PYTHON_BIN=python3

# Auto-update from GitHub.
DECKWEAVER_AUTO_UPDATE=true
DECKWEAVER_UPDATE_POLL_SECONDS=600
DECKWEAVER_GIT_REMOTE=origin
DECKWEAVER_GIT_BRANCH=main
DECKWEAVER_GITHUB_REPO_URL=https://github.com/GuopengLin/Image2PPT

# CORS — only needed if you serve the frontend from a different origin.
DECKWEAVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Sandboxing & resource limits ---
# Filesystem sandbox for the convert.py subprocess.
#   auto  – pick best available (sandbox-exec on macOS, bwrap or firejail on Linux)
#   none  – disable FS sandbox (rlimits + env scrubbing still apply)
#   sandbox-exec | bwrap | firejail – force a backend
DECKWEAVER_SANDBOX_MODE=auto
# First-run model downloads need network. Set false after caches are warm.
DECKWEAVER_SANDBOX_ALLOW_NETWORK=true

# Hard caps on the conversion subprocess (any 0 disables that one).
DECKWEAVER_SUBPROCESS_MEMORY_MB=6144
DECKWEAVER_SUBPROCESS_CPU_SECONDS=3600
DECKWEAVER_SUBPROCESS_OUTPUT_MB=512

# Upload caps.
DECKWEAVER_MAX_UPLOAD_MB=200
DECKWEAVER_MAX_FILES=100
DECKWEAVER_MAX_SINGLE_FILE_MB=100
DECKWEAVER_ZIP_MAX_ENTRIES=500
DECKWEAVER_ZIP_MAX_UNCOMPRESSED_MB=1024

# Per-user job throttling.
DECKWEAVER_PER_USER_ACTIVE_JOBS=2     # max queued+running per user
DECKWEAVER_PER_USER_TOTAL_JOBS=50     # max jobs in DB per user

# Rate limiting on /api/auth/login (per IP). 0 disables.
DECKWEAVER_LOGIN_RATE_PER_MIN=10

# Auto-cleanup of finished jobs (done/failed/canceled). 0 disables.
DECKWEAVER_JOB_RETENTION_DAYS=30
